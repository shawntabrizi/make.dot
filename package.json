{
  "name": "hello-playground",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit",
    "preview": "vite preview",
    "deploy:dot": "dot deploy --domain hello-playground",
    "postinstall": "patch-package && papi generate"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@ensdomains/content-hash": "^3.0.0",
    "@noble/hashes": "^1.4.0",
    "@novasamatech/host-api": "0.8.6",
    "@novasamatech/host-api-wrapper": "0.8.6",
    "@parity/product-sdk-address": "^0.1.1",
    "@parity/product-sdk-chain-client": "^0.6.1",
    "@parity/product-sdk-cloud-storage": "^0.5.5",
    "@parity/product-sdk-contracts": "^0.7.2",
    "@parity/product-sdk-crypto": "^0.1.1",
    "@parity/product-sdk-descriptors": "^0.5.2",
    "@parity/product-sdk-host": "^0.7.1",
    "@parity/product-sdk-keys": "^0.3.5",
    "@parity/product-sdk-logger": "^0.1.1",
    "@parity/product-sdk-storage": "^0.1.5",
    "@parity/product-sdk-tx": "^0.2.9",
    "@parity/product-sdk-utils": "^0.1.1",
    "@polkadot-api/descriptors": "file:.papi/descriptors",
    "@polkadot-labs/hdkd-helpers": "^0.0.29",
    "marked": "^18.0.4",
    "multiformats": "^13.3.1",
    "polkadot-api": "^2.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "viem": "^2.49.3"
  },
  "_comment_overrides": "Mirrors playground-app-template's overrides — @polkadot-api/json-rpc-provider is the standard upstream workaround.",
  "overrides": {
    "@novasamatech/host-api": "0.8.6",
    "@novasamatech/host-api-wrapper": "0.8.6",
    "@polkadot-api/json-rpc-provider": "^0.2.0"
  },
  "devDependencies": {
    "@polkadot-api/cli": "^0.21.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "patch-package": "^8.0.1",
    "typescript": "^5.9.0",
    "vite": "^7.0.0"
  }
}
